@namespace WebFormSiteOracleDB.Components.ViewSwitcher

@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ILogger<ViewSwitcher> Logger
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Logging

@if (isVisible)
{
    <div id="viewSwitcher">
        @CurrentView view | <NavLink href="@SwitchUrl" data-ajax="false">Switch to @AlternateView</NavLink>
    </div>
}

@code {
    private string CurrentView { get; set; } = string.Empty;
    private string AlternateView { get; set; } = string.Empty;
    private string SwitchUrl { get; set; } = string.Empty;
    private bool isVisible = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var isMobile = await JSRuntime.InvokeAsync<bool>("eval",
                    "/Mobi|Android/i.test(navigator.userAgent)");

                CurrentView = isMobile ? "Mobile" : "Desktop";
                AlternateView = isMobile ? "Desktop" : "Mobile";

                var currentUri = NavigationManager.Uri;
                var returnUrl = Uri.EscapeDataString(
                    "/" + NavigationManager.ToBaseRelativePath(currentUri));

                SwitchUrl = $"/__FriendlyUrls_SwitchView/{AlternateView}?ReturnUrl={returnUrl}";

                Logger.LogInformation("ViewSwitcher initialized. CurrentView: {CurrentView}, AlternateView: {AlternateView}",
                    CurrentView, AlternateView);

                StateHasChanged();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error initializing ViewSwitcher.");
                isVisible = false;
                StateHasChanged();
            }
        }
    }
}