@model WebApp6UnitTestsandIdentity.Models.ExternalLoginListViewModel
@using Microsoft.AspNetCore.Authentication

<h4>Use another service to log in.</h4>
<hr />
@{
    var loginProviders = ViewBag.LoginProviders as IEnumerable<AuthenticationScheme> ?? Enumerable.Empty<AuthenticationScheme>();
    if (loginProviders.Count() == 0) {
        <div>
            <p>
                There are no external authentication services configured. See <a href="https://go.microsoft.com/fwlink/?LinkId=403804">this article</a>
                for details on setting up this ASP.NET application to support logging in via external services.
            </p>
        </div>
    }
    else {
using (Html.BeginForm("ExternalLogin", "Account", new { ReturnUrl = Model.ReturnUrl }, FormMethod.Post, false, new { role = "form" })) {
            @Html.AntiForgeryToken()
            <div id="socialLoginList">
                <p>
                    @foreach (AuthenticationScheme p in loginProviders) {
<button type="submit" class="btn btn-outline-dark" id="@p.Name" name="provider" value="@p.Name" title="Log in using your @p.DisplayName account">@p.Name</button>
                    }
                </p>
            </div>
        }
    }
}