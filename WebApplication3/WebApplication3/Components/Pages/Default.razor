@namespace WebApplication3.Components.Pages.Default

@page "/"
@page "/Default"

@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Logging
@using System.Data
@using Microsoft.Data.SqlClient






@inject IConfiguration Configuration
@inject ILogger<Default> Logger

<PageTitle>Home Page</PageTitle>

<main>
    <section class="row" aria-labelledby="aspnetTitle">
        <h1 id="aspnetTitle">Title - Header</h1>
    </section>

    <div>
        @if (_companies == null)
        {
            <p><em>Loading...</em></p>
        }
        else if (_companies.Count == 0)
        {
            <p><em>No records found.</em></p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>COMPANY_NAME</th>
                        <th>HQ_ADDRESS</th>
                        <th>INCOME_OUTCOME</th>
                        <th>NUMBER_OF_SALESMEN</th>
                        <th>NUMBER_OF_FACTORIES</th>
                        <th>NEW_DRUG_RATE</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _companies)
                    {
                        <tr>
                            <td>@row.CompanyName</td>
                            <td>@row.HqAddress</td>
                            <td>@row.IncomeOutcome</td>
                            <td>@row.NumberOfSalesmen</td>
                            <td>@row.NumberOfFactories</td>
                            <td>@row.NewDrugRate</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <p class="text-danger">@_errorMessage</p>
        }
    </div>
</main>

@code {
    private List<CompanyModel> _companies;
    private string _errorMessage;
    private string _connectionString;

    protected override async Task OnInitializedAsync()
    {
        _connectionString = Configuration.GetConnectionString("ConnectionString1");
        await LoadCompaniesAsync();
    }

    private async Task LoadCompaniesAsync()
    {
        _companies = new List<CompanyModel>();

        try
        {
using (var connection = new SqlConnection(_connectionString))
            {
                await connection.OpenAsync();

                var selectCommand = @"SELECT * FROM ""user_test"".COMPANY";

using (var command = new SqlCommand(selectCommand, connection))
                using (var reader = await command.ExecuteReaderAsync())
                {
                    while (await reader.ReadAsync())
                    {
                        var company = new CompanyModel
                        {
                            CompanyName      = reader["COMPANY_NAME"]      == DBNull.Value ? null : reader["COMPANY_NAME"].ToString(),
                            HqAddress        = reader["HQ_ADDRESS"]        == DBNull.Value ? null : reader["HQ_ADDRESS"].ToString(),
                            IncomeOutcome    = reader["INCOME_OUTCOME"]    == DBNull.Value ? null : reader["INCOME_OUTCOME"].ToString(),
                            NumberOfSalesmen = reader["NUMBER_OF_SALESMEN"] == DBNull.Value ? null : reader["NUMBER_OF_SALESMEN"].ToString(),
                            NumberOfFactories= reader["NUMBER_OF_FACTORIES"]== DBNull.Value ? null : reader["NUMBER_OF_FACTORIES"].ToString(),
                            NewDrugRate      = reader["NEW_DRUG_RATE"]     == DBNull.Value ? null : reader["NEW_DRUG_RATE"].ToString()
                        };
                        _companies.Add(company);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading company data.");
            _errorMessage = "An error occurred while loading data.";
        }
    }

    private class CompanyModel
    {
        public string CompanyName       { get; set; }
        public string HqAddress         { get; set; }
        public string IncomeOutcome     { get; set; }
        public string NumberOfSalesmen  { get; set; }
        public string NumberOfFactories { get; set; }
        public string NewDrugRate       { get; set; }
    }
}